# Notion 整合 Token（從 https://www.notion.so/my-integrations 取得）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 業務專案資料庫的 ID（URL 中 notion.so/ 後面那串）
NOTION_DATABASE_ID=25d2cda48d7781a6bec3f101d8c9a872

# Anthropic API Key（圖片辨識、LINE客服第二層判斷用，從 console.anthropic.com 取得）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API Key（LINE客服第一層分類、知識庫等功能用，從 aistudio.google.com/apikey 取得）
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LINE 官方帳號（Messaging API），從 LINE Developers Console 的該 Channel 頁面取得
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 需要真人處理時，推播通知的對象（員工群組 ID 或個人 userId）
LINE_TARGET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
